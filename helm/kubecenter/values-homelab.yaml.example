# ============================================================
# EXAMPLE homelab values file for k8sCenter (k3s ARM64, 3 nodes)
#
# USAGE:
#   1. Copy this file:  cp values-homelab.yaml.example values-homelab.yaml
#   2. Replace every REPLACE_ME_* placeholder with a real secret.
#      Generate secrets with:
#        openssl rand -base64 48   # for JWT / setup token
#        openssl rand -base64 32   # for Postgres password
#   3. Keep values-homelab.yaml out of git — see .gitignore.
#
# FAST-FAIL GUARD:
#   The Helm chart (_validate.tpl) will REFUSE to render if any
#   REPLACE_ME_* placeholder survives into a rendered release, or if
#   a known-leaked string from the 2026-05-22 security audit appears.
#   You MUST replace all placeholders before running helm install/upgrade.
# ============================================================

replicaCount: 1

backend:
  image:
    repository: ghcr.io/maulepilot117/k8scenter-backend
    # P3-9 (2026-05-22 audit): \`latest\` is mutable. Pin to a specific
    # \`sha-<commit>\` (every merge to main publishes one) or the
    # current \`v<chartAppVersion>\` release. Argocd-image-updater
    # rewrites this in place, so the value here is the bootstrap
    # value used before the first sync — it should not be \`latest\`
    # on a fresh install of a publicly-reachable cluster. Pick the
    # most recent \`v*\` tag from the GHCR package page.
    tag: REPLACE_ME_BACKEND_TAG  # e.g. v0.42.0 or sha-abc1234
    pullPolicy: Always
  config:
    dev: true  # relaxes rate limiting to 60 req/min for homelab

frontend:
  image:
    repository: ghcr.io/maulepilot117/k8scenter-frontend
    # P3-9 (2026-05-22 audit): see backend.image.tag note above.
    tag: REPLACE_ME_FRONTEND_TAG  # e.g. v0.42.0 or sha-abc1234
    pullPolicy: Always
  resources:
    requests:
      cpu: 50m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi

imagePullSecrets: []
# Release images are public on GHCR — no pull secret needed
# For dev/test images, add: imagePullSecrets: [{name: ghcr-pull-secret}]

auth:
  jwtSecret: "REPLACE_ME_JWT_SECRET_MIN_32_BYTES"
  setupToken: "REPLACE_ME_SETUP_TOKEN"

# Homelab consciously accepts the plaintext-exposure risk: service.type
# below is LoadBalancer (no upstream TLS termination), backend.config.dev
# is true (relaxed rate limits + non-Secure cookies), and the LAN is
# treated as a trust boundary. Set to false and add an HTTPS ingress for
# anything that leaves the homelab.
security:
  insecureExposureAcknowledged: true

service:
  type: LoadBalancer
  port: 8080
  frontendPort: 8000

ingress:
  enabled: false

networkPolicy:
  enabled: false  # Disabled — Cilium NP port-filtering blocks cross-namespace gRPC (Hubble Relay)

postgresql:
  enabled: true
  image:
    tag: latest  # latest has ARM64 support; pinned tags may not
  auth:
    username: k8scenter
    password: "REPLACE_ME_POSTGRES_PASSWORD"
    database: k8scenter
  primary:
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi
    persistence:
      storageClass: local-path
      size: 5Gi
    podSecurityContext:
      enabled: false
    containerSecurityContext:
      enabled: false
