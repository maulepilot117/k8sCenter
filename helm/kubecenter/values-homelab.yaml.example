# ============================================================
# EXAMPLE homelab values file for k8sCenter (k3s ARM64, 3 nodes)
#
# USAGE:
#   1. Copy this file:  cp values-homelab.yaml.example values-homelab.yaml
#   2. Replace every REPLACE_ME_* placeholder with a real secret.
#      Generate secrets with:
#        openssl rand -base64 48   # for JWT / setup token
#        openssl rand -base64 32   # for Postgres password
#   3. Keep values-homelab.yaml out of git — see .gitignore.
#
# FAST-FAIL GUARD:
#   The Helm chart (_validate.tpl) will REFUSE to render if any
#   REPLACE_ME_* placeholder survives into a rendered release, or if
#   a known-leaked string from the 2026-05-22 security audit appears.
#   You MUST replace all placeholders before running helm install/upgrade.
# ============================================================

replicaCount: 1

backend:
  image:
    repository: ghcr.io/maulepilot117/k8scenter-backend
    tag: latest  # overridden at runtime by argocd-image-updater → sha-<commit>
    pullPolicy: Always
  config:
    dev: true  # relaxes rate limiting to 60 req/min for homelab

frontend:
  image:
    repository: ghcr.io/maulepilot117/k8scenter-frontend
    tag: latest  # overridden at runtime by argocd-image-updater → sha-<commit>
    pullPolicy: Always
  resources:
    requests:
      cpu: 50m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi

imagePullSecrets: []
# Release images are public on GHCR — no pull secret needed
# For dev/test images, add: imagePullSecrets: [{name: ghcr-pull-secret}]

auth:
  jwtSecret: "REPLACE_ME_JWT_SECRET_MIN_32_BYTES"
  setupToken: "REPLACE_ME_SETUP_TOKEN"

service:
  type: LoadBalancer
  port: 8080
  frontendPort: 8000

ingress:
  enabled: false

networkPolicy:
  enabled: false  # Disabled — Cilium NP port-filtering blocks cross-namespace gRPC (Hubble Relay)

postgresql:
  enabled: true
  image:
    tag: latest  # latest has ARM64 support; pinned tags may not
  auth:
    username: k8scenter
    password: "REPLACE_ME_POSTGRES_PASSWORD"
    database: k8scenter
  primary:
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi
    persistence:
      storageClass: local-path
      size: 5Gi
    podSecurityContext:
      enabled: false
    containerSecurityContext:
      enabled: false
