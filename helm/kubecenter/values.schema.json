{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "k8sCenter Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "backend": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "required": ["repository"]
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "config": {
          "type": "object",
          "properties": {
            "dev": { "type": "boolean" },
            "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
            "logFormat": { "type": "string", "enum": ["json", "text"] },
            "clusterID": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "frontend": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "jwtSecret": { "type": "string" },
        "setupToken": { "type": "string" },
        "oidc": { "type": "array" },
        "ldap": { "type": "array" }
      }
    },
    "alerting": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "retentionDays": { "type": "integer", "minimum": 1 },
        "rateLimit": { "type": "integer", "minimum": 1 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "mobile": {
      "type": "object",
      "description": "Mobile app Universal Link domain hosting — opt-in.",
      "properties": {
        "universalLinkDomain": {
          "type": "string",
          "description": "Public host serving Universal Link well-known files. Empty = disabled."
        },
        "iosTeamId": {
          "type": "string",
          "description": "Apple Developer Team ID. Required when universalLinkDomain is set."
        },
        "iosBundleId": {
          "type": "string",
          "description": "iOS bundle identifier."
        },
        "androidPackageName": {
          "type": "string",
          "description": "Android application package name."
        },
        "androidSha256CertFingerprint": {
          "type": "string",
          "description": "SHA-256 fingerprint of the Android upload signing certificate (colon-separated hex). Required when universalLinkDomain is set."
        },
        "wellKnownImage": {
          "type": "string",
          "description": "Distroless nginx image for the well-known Pod. Empty = cgr.dev/chainguard/nginx:latest."
        }
      }
    }
  }
}
