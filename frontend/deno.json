{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test -A"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "fresh/runtime": "jsr:@fresh/core@^2.2.0/runtime",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.0",
    "@fresh/plugin-tailwind": "jsr:@fresh/plugin-tailwind@^1.0.0",
    "preact": "npm:preact@^10.28.3",
    "preact/hooks": "npm:preact@^10.28.3/hooks",
    "@preact/signals": "npm:@preact/signals@^2.7.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.10",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "yaml": "npm:yaml@^2.7.1",
    "@codemirror/state": "npm:@codemirror/state@^6.6.0",
    "@codemirror/view": "npm:@codemirror/view@^6.40.0",
    "@codemirror/commands": "npm:@codemirror/commands@^6.10.3",
    "@codemirror/language": "npm:@codemirror/language@^6.12.2",
    "@codemirror/lang-yaml": "npm:@codemirror/lang-yaml@^6.1.2",
    "@codemirror/search": "npm:@codemirror/search@^6.5.11",
    "@codemirror/theme-one-dark": "npm:@codemirror/theme-one-dark@^6.1.3",
    "ansi_up": "npm:ansi_up@^6.0.2",
    "@xterm/xterm": "npm:@xterm/xterm@^5.5.0",
    "@xterm/addon-fit": "npm:@xterm/addon-fit@^0.10.0",
    "@xterm/addon-web-links": "npm:@xterm/addon-web-links@^0.11.0",
    "fuse.js": "npm:fuse.js@^7.1.0",
    "d3-force": "npm:d3-force@^3.0.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
