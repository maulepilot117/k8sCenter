# Helm
helm/kubecenter/charts/*.tgz

# Operator-local values files — committed homelab values led to the
# 2026-05-22 security audit's P0-1 finding. Only the *.example
# template form is permitted in-tree.
helm/kubecenter/values-homelab.yaml
helm/kubecenter/values-*.local.yaml

# Android upload signing material — CI writes these from the
# ANDROID_UPLOAD_* secrets at run time (finding P1-5). They must
# never be committed; an attacker with the upload key can sign
# malicious updates as the legitimate app identity.
mobile/android/key.properties
mobile/android/upload-keystore.jks
mobile/android/*.jks

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12

# SQLite
*.db
*.db-journal
*.db-wal
*.db-shm

# Docker
docker-compose.override.yml

# E2E tests (Playwright)
e2e/node_modules/
e2e/playwright/.auth/
e2e/playwright-report/
e2e/blob-report/
e2e/test-results/

# Theme generator runtime cache
tools/theme-gen/deno.lock

# Misc
*.log
*.tmp
*.png
.superpowers/
.worktrees

# Claude Code scheduling state
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Claude Code per-subagent isolated worktrees
