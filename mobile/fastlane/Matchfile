# Fastlane match config. The actual git repo URL comes from the
# MATCH_GIT_URL secret at CI time so this checked-in file doesn't leak
# the cert-storage repo identity. Storage backend is git (encrypted via
# MATCH_PASSWORD); operators may switch to S3 by adjusting the workflow.

storage_mode("git")
# `type` intentionally not set here — Fastfile passes `type:` per lane
# so a future development/adhoc lane can request its own cert type
# without the Matchfile default fighting the call site.
app_identifier(["io.kubecenter.kubecenter"])
readonly(true)
